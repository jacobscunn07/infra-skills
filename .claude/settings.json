{
  "env": {},
  "enabledMcpjsonServers": [
    "terraform-registry"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/document-environment.py",
            "description": "Inject installed CLI tool versions into session context at session start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/block-dangerous-commands.py",
            "description": "Block dangerous / destructive commands that require explicit human approval"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/block-commit-on-main.py",
            "description": "Block git commits on main/master — use a feature branch instead"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/log-tool-activity.py",
            "description": "Log all Bash tool calls to <repo-root>/.claude/logs/tool-activity.log; include [project:<name>] for terraform commands"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/log-tool-activity.py",
            "description": "Log all Write tool calls to <repo-root>/.claude/logs/tool-activity.log with project context"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/log-tool-activity.py",
            "description": "Log all Edit tool calls to <repo-root>/.claude/logs/tool-activity.log with project context"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(terraform validate:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform init:*)",
      "Bash(terraform output:*)",
      "Bash(terraform show:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(aws ec2 describe-*:*)",
      "Bash(aws rds describe-*:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws cloudformation describe-*:*)"
    ],
    "deny": [
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(terraform force-unlock:*)",
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)",
      "Bash(aws iam delete-*:*)",
      "Bash(aws s3 rb:*)",
      "Bash(aws ec2 terminate-instances:*)",
      "Bash(kubectl delete namespace:*)"
    ]
  }
}
